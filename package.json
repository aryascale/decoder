{
  "name": "race-leaderboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "concurrently \"vite\" \"node mock-server.js\"",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "build:server": "tsc -p tsconfig.server.json && node scripts/fix-imports.mjs",
    "build:all": "npm run build && npm run build:server",
    "postinstall": "npx prisma generate || true",
    "preview": "vite preview",
    "server": "tsx server.ts",
    "start": "NODE_ENV=production node dist-server/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:backup": "bash scripts/db-backup.sh",
    "db:reset": "bash scripts/db-reset.sh"
  },
  "dependencies": {
